# PostgreSQL connection string (provided by Railway)
DATABASE_URL="postgresql://user:password@host:5432/parky"

# Secret token for the cron endpoint — generate with: openssl rand -hex 32
CRON_SECRET="your-secret-here"

# Set to your Railway app URL for the cron job (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"
